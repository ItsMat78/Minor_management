PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/minor_management

# Required: generate a strong secret, e.g. openssl rand -hex 32
JWT_SECRET=

# Email (Nodemailer / SMTP) --------------------------------------------------
# Use a transactional email service (Resend recommended) instead of personal Gmail.
# Gmail will block or throttle bulk sends; transactional services handle SPF/DKIM for you.
#
# Resend SMTP settings (sign up at resend.com, verify your domain, generate an API key):
#   EMAIL_HOST=smtp.resend.com
#   EMAIL_PORT=465
#   EMAIL_SECURE=true
#   EMAIL_USER=resend              ← literal string, not your email
#   EMAIL_PASS=re_xxxxxxxxxxxx     ← your Resend API key
#   EMAIL_FROM=no-reply@minor.iiitnr.ac.in   ← verified sender domain
#   EMAIL_REPLY_TO=btechminiproject@iiitnr.edu.in
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=resend
EMAIL_PASS=
# The address that appears in the From field — must match your verified Resend domain
EMAIL_FROM=no-reply@minor.iiitnr.ac.in
# Where students/faculty replies actually go (a monitored mailbox)
EMAIL_REPLY_TO=btechminiproject@iiitnr.edu.in

# File storage ---------------------------------------------------------------
# Local disk by default. Leave UPLOAD_DIR empty to use server/uploads/.
# Switch to the IIITNR NAS mount path later, e.g. //fileserver/minor_portal/uploads
UPLOAD_DIR=
# Public base URL used to build file URLs. Leave empty to derive from request.
# Set this in production when behind a reverse proxy, e.g. https://portal.iiitnr.ac.in
UPLOAD_BASE_URL=

# Admin seeding (one-time use) ------------------------------------------------
# Set a strong secret here, pass the same value via ADMIN_SETUP_SECRET when running
# the seed script. Delete seedAdmin.ts after first use.
# ADMIN_SETUP_SECRET_VALUE=change-this-to-a-strong-random-secret
# ADMIN_EMAIL=admin@iiitnr.edu.in
# ADMIN_PASSWORD=changeme
