PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/minor_management

# Required: generate a strong secret, e.g. openssl rand -hex 32
JWT_SECRET=

# Email (Nodemailer / SMTP) --------------------------------------------------
# Use a transactional email service (Resend recommended) instead of personal Gmail.
# Gmail will block or throttle bulk sends; transactional services handle SPF/DKIM for you.
#
# Resend SMTP settings (sign up at resend.com, verify your domain, generate an API key):
#   EMAIL_HOST=smtp.resend.com
#   EMAIL_PORT=465
#   EMAIL_SECURE=true
#   EMAIL_USER=resend              ← literal string, not your email
#   EMAIL_PASS=re_xxxxxxxxxxxx     ← your Resend API key
#   EMAIL_FROM=no-reply@minor.iiitnr.ac.in   ← verified sender domain
#   EMAIL_REPLY_TO=btechminiproject@iiitnr.edu.in
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=resend
EMAIL_PASS=
# The address that appears in the From field — must match your verified Resend domain
EMAIL_FROM=no-reply@iiitnr.edu.in
# Where students/faculty replies actually go (a monitored mailbox)
EMAIL_REPLY_TO=btechminiproject@iiitnr.edu.in

# File storage ---------------------------------------------------------------
# Local disk by default. Leave UPLOAD_DIR empty to use server/uploads/.
# Switch to the IIITNR NAS mount path later, e.g. //fileserver/minor_portal/uploads
UPLOAD_DIR=
# Public base URL used to build file URLs. Leave empty to derive from request.
# Set this in production when behind a reverse proxy, e.g. https://portal.iiitnr.ac.in
UPLOAD_BASE_URL=

# Reverse proxy / rate limiting ----------------------------------------------
# TRUST_PROXY tells Express how many proxy hops to trust so req.ip is the REAL client IP
# (read from X-Forwarded-For). The per-IP auth rate limiter and request logging depend on
# this. WITHOUT it, every request behind the proxy looks like it comes from the proxy's IP,
# so the 300/min per-IP backstop becomes one shared global bucket.
#
# Set it to the number of trusted proxies in front of Node, counting from the outermost:
#   1  -> a single reverse proxy (typical: one nginx/Apache in front of Node)  <-- prod default
#   2  -> institute edge proxy + a local nginx, etc.
# Do NOT use "true" (trust everything): that lets any client spoof X-Forwarded-For and dodge
# the IP limiter. Use the exact hop count.
# Leave EMPTY for local dev (Node exposed directly, no proxy). In production behind nginx,
# set TRUST_PROXY=1. To confirm the count is right: temporarily log req.ip +
# req.headers['x-forwarded-for'] and hit it from your real machine — req.ip should be YOUR
# public IP, not 127.0.0.1 or the proxy's address.
TRUST_PROXY=

# CORS allowed browser origins (comma-separated). These ADD to the built-in defaults
# (localhost:5173, the vercel app, and http/https minor-project.iiitnr.ac.in), so the prod
# domain already works without setting this. Use it for extra/staging frontends, e.g.
#   CORS_ORIGINS=https://staging.minor-project.iiitnr.ac.in
CORS_ORIGINS=

# Admin seeding (one-time use) ------------------------------------------------
# Set a strong secret here, pass the same value via ADMIN_SETUP_SECRET when running
# the seed script. Delete seedAdmin.ts after first use.
# ADMIN_SETUP_SECRET_VALUE=change-this-to-a-strong-random-secret
# ADMIN_EMAIL=admin@iiitnr.edu.in
# ADMIN_PASSWORD=changeme
