PORT=5000
MONGO_URI=mongodb://127.0.0.1:27017/minor_management

# Required: generate a strong secret, e.g. openssl rand -hex 32
JWT_SECRET=

# Email (Nodemailer / SMTP) --------------------------------------------------
# EMAIL_USER is the *sending* account (create a dedicated bot mailbox, e.g.
#   minorportal.bot@iiitnr.edu.in). Notifications will show up as "from" this.
# EMAIL_REPLY_TO is the human address students/faculty should reply to, e.g.
#   btechminiproject@iiitnr.edu.in (the MinorProjectCoordinator mailbox).
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=minorportal.bot@iiitnr.edu.in
# For Gmail / Google Workspace: use an App Password
EMAIL_PASS=your_app_password
EMAIL_REPLY_TO=btechminiproject@iiitnr.edu.in

# File storage ---------------------------------------------------------------
# Local disk by default. Leave UPLOAD_DIR empty to use server/uploads/.
# Switch to the IIITNR NAS mount path later, e.g. //fileserver/minor_portal/uploads
UPLOAD_DIR=
# Public base URL used to build file URLs. Leave empty to derive from request.
# Set this in production when behind a reverse proxy, e.g. https://portal.iiitnr.ac.in
UPLOAD_BASE_URL=

# Admin seeding (one-time use) ------------------------------------------------
# Set a strong secret here, pass the same value via ADMIN_SETUP_SECRET when running
# the seed script. Delete seedAdmin.ts after first use.
# ADMIN_SETUP_SECRET_VALUE=change-this-to-a-strong-random-secret
# ADMIN_EMAIL=admin@iiitnr.edu.in
# ADMIN_PASSWORD=changeme
